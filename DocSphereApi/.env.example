# ──────────────────────────────────────────────────────
# DocSphere — Environment Variable Template
# Copy this file to .env and fill in your real values.
# This file IS safe to commit — it contains no secrets.
# ──────────────────────────────────────────────────────

# MongoDB
MONGODB_URI=mongodb://localhost:27017/DocSphere

# Clerk Auth
CLERK_ISSUER=https://<YOUR_CLERK_DOMAIN>.clerk.accounts.dev
CLERK_JWKS_URL=https://<YOUR_CLERK_DOMAIN>.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=<YOUR_CLERK_WEBHOOK_SECRET>

# Razorpay
RAZORPAY_KEY_ID=<YOUR_RAZORPAY_KEY_ID>
RAZORPAY_KEY_SECRET=<YOUR_RAZORPAY_KEY_SECRET>

# Supabase S3 Storage
SUPABASE_S3_ENDPOINT_URL=https://<PROJECT_ID>.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY=<YOUR_SUPABASE_ACCESS_KEY>
SUPABASE_S3_SECRET_KEY=<YOUR_SUPABASE_SECRET_KEY>
SUPABASE_S3_REGION=<YOUR_REGION>
SUPABASE_S3_BUCKET_NAME=<YOUR_BUCKET_NAME>
